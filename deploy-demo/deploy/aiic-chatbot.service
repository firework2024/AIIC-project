[Unit]
Description=AIIC Chatbot FastAPI service
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/aiic-deploy/AIIC-project/deploy-demo
EnvironmentFile=/etc/aiic-chatbot.env
ExecStart=/root/aiic-deploy/AIIC-project/deploy-demo/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
